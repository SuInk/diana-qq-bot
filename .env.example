# Copy this file to .env for Docker Compose or to runtime.env for the
# macOS launcher. Never commit the populated file.

# HTTP server. Use 127.0.0.1 for local-only access.
HOST=0.0.0.0
PORT=18080
APP_DB_PATH=data/diana-qq-bot.db
LOG_PATH=logs/diana-qq-bot.log

# WebUI authentication. Generate with: openssl rand -hex 32
DIANA_ADMIN_TOKEN=
DIANA_ADMIN_LOGIN_PATH=

# NapCat WebUI integration (optional).
DIANA_NAPCAT_WEBUI_URL=
DIANA_NAPCAT_WEBUI_TOKEN=

# OneBot / QQ identity.
QQBOT_ENABLED=false
QQBOT_QQ=
DIANA_OWNER_ID=
DIANA_GROUP_TRIGGERS=Diana,diana
ONEBOT_REVERSE_WS_ENDPOINT=ws://127.0.0.1:18080/onebot/v11/ws
ONEBOT_ACCESS_TOKEN=

# LLM provider. These values can also be managed in the WebUI.
LLM_PROVIDER=openai_compatible
LLM_API_KEY=
LLM_BASE_URL=
LLM_API_FORMAT=responses
LLM_MODEL=gpt-4o-mini
LLM_USER_AGENT=diana-qq-bot
LLM_TIMEOUT_MS=60000
LLM_CONTEXT_WINDOW_TOKENS=16384
LLM_MAX_CONTEXT_TOKENS=16384
LLM_MAX_OUTPUT_TOKENS=1024

# Optional image generation endpoint/model.
LLM_IMAGE_MODEL=
LLM_IMAGE_BASE_URL=
LLM_IMAGE_ORIGIN=
LLM_IMAGE_TIMEOUT_MS=

# Agent and search configuration.
DIANA_AGENT_ENABLED=true
DIANA_AGENT_WORK_DIR=.
DIANA_AGENT_SKILL_ROOTS=skills
DIANA_AGENT_MCP_CONFIG=.mcp.json
DIANA_WEB_SEARCH_CONFIG_FILE=web-search.json

# Optional GPT-SoVITS voice. The reference audio or fine-tuned model decides
# the actual voice; the display name is only used in plugin descriptions.
DIANA_TTS_VOICE_NAME=custom
DIANA_TTS_ENDPOINT=http://127.0.0.1:9880/tts
DIANA_TTS_API_KEY=
DIANA_TTS_REF_AUDIO_PATH=
DIANA_TTS_PROMPT_TEXT=
DIANA_TTS_TEXT_LANG=zh
DIANA_TTS_PROMPT_LANG=zh
DIANA_TTS_SPEED_FACTOR=1.0
DIANA_TTS_FFMPEG_PATH=ffmpeg
DIANA_TTS_SILK_ENCODER_PATH=

# Platform cookies are optional and must stay local.
DIANA_BILI_SESSDATA=
DIANA_DOUYIN_CK=
DIANA_XHS_CK=
DIANA_YTDLP_COOKIES=
